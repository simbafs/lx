{
  "name": "@simbafs/lx",
  "version": "0.7.4",
  "description": "HTML attribute DSL for absolute positioning",
  "main": "dist/index.min.js",
  "scripts": {
    "clean": "rm -rf dist test-results playwright-report",
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "pnpm run test:unit && pnpm run test:e2e"
  },
  "keywords": [
    "layout",
    "positioning",
    "css",
    "html",
    "attributes"
  ],
  "repository": "github:simbafs/lx",
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@vitest/browser": "^4.1.4",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "serve": "^14.2.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
